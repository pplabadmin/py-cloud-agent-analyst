# .env TEMPLATE

# --- GOOGLE CLOUD CONFIGURATION ---
# The ID of your GCP Project where BigQuery datasets are hosted.
PROJECT_ID=your-gcp-project-id

# --- GEMINI LLM CONFIGURATION ---
# Your Google AI API Key (from AI Studio).
GOOGLE_API_KEY=your-gemini-api-key

# Optional: Override default model (default: gemini-1.5-pro)
# GEMINI_MODEL=gemini-2.5-pro

# Optional: Override default temperature (default: 0.0)
# GEMINI_TEMPERATURE=0.0

# --- DATA CONFIGURATION ---
# The target BigQuery dataset for MiBici GDL.
DATASET_ID=mibici_gdl